# Секреты обработчика заявки /api/lead (serverless-функция).
# Скопируйте в .env и заполните. Значения задаются в переменных окружения
# облачной функции (Yandex Cloud Functions / Timeweb). В репозиторий НЕ коммитить.

# Telegram (минимум один канал доставки — обязателен)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# E-mail (опционально; включается при заданных SMTP_*)
MAIL_TO=info@ostvera.ru
MAIL_FROM=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# CORS
ALLOW_ORIGIN=https://ostvera.ru
