---
import Base from '../layouts/Base.astro';
import type { Locale } from '../i18n/utils';
interface Props { lang: Locale; title: string; description?: string; path: string; heading: string; kicker?: string; }
const { lang, title, description = '', path, heading, kicker } = Astro.props;
---
<Base lang={lang} title={title} description={description} path={path}>
  <section class="inner">
    <div class="wrap">
      <div class="sec__hd">
        <div class="sec__no">—</div>
        <div class="sec__h">
          {kicker && <span class="eyebrow">{kicker}</span>}
          <h2 style="margin-top:10px">{heading}</h2>
        </div>
      </div>
      <div class="prose legal">
        <slot />
      </div>
    </div>
  </section>
</Base>
