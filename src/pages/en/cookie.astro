---
import InnerPage from '../../components/InnerPage.astro';
const lang = 'en' as const;
---
<InnerPage lang={lang} path="/cookie" title="Cookie notice — Ostvera" description="How the Ostvera website uses cookies and web analytics." heading="Cookie notice" kicker="Cookie">
  <p class="lead">The website uses cookies and web analytics to function correctly and improve the service.</p>
  <h2>Cookies we use</h2>
  <ul>
    <li>Technical &mdash; required for the site to work.</li>
    <li>Analytics &mdash; visit statistics (e.g. Yandex.Metrica).</li>
  </ul>
  <p>By continuing to use the site you agree to the use of cookies. You can disable cookies in your browser settings.</p>
</InnerPage>
